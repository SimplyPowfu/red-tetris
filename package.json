{
  "name": "red-tetris",
  "version": "0.0.1",
  "author": "ecarbona, topiana-",
  "license": "MIT",
  "scripts": {
    "eslint": "eslint src",
    "client-dist": "NODE_ENV=production webpack --progress --colors",
    "client-dev": "webpack-dev-server --colors --hot --inline --history-api-fallback --host 0.0.0.0 --port 8080",
    "srv-dev": "DEBUG=tetris:* babel-watch -w src src/server/main.js",
    "srv-dist": "DEBUG=tetris:* babel src --out-dir dist",
    "test:logic": "mocha --require babel-core/register --require ignore-styles test/logic",
    "test:ui": "mocha --require babel-core/register --require ./test/ui/setup.js --require ignore-styles test/ui",
    "test": "npm run test:logic && npm run test:ui",
"coverage:clean": "rm -rf .nyc_output coverage",
  
  "coverage:logic": "NODE_ENV=test nyc --silent --no-clean --instrument false mocha --require babel-core/register --require ignore-styles --require ./test/.scripts/dump-coverage.js test/logic",
  
  "coverage:ui": "NODE_ENV=test nyc --silent --no-clean --instrument false mocha --require babel-polyfill --require babel-core/register --require ./test/ui/setup.js --require ignore-styles --require ./test/.scripts/dump-coverage.js test/ui",
  
"coverage:report": "node test/.scripts/merge-reports.js && istanbul report lcov text",

  "coverage": "npm run coverage:clean && npm run coverage:logic && npm run coverage:ui && npm run coverage:report"  },
"dependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-redux": "^7.2.5",
    "react-router-dom": "^5.3.3",
    "redux": "^3.5.2",
    "redux-logger": "^2.6.1",
    "redux-thunk": "2.3.0",
    "socket.io": "^1.4.6"
  },
  "devDependencies": {
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^14.6.1",
    "babel-cli": "^6.7.7",
    "babel-core": "^6.26.3",
    "babel-eslint": "^6.1.0",
    "babel-loader": "^6.2.4",
    "babel-plugin-__coverage__": "^0.111111.1",
    "babel-polyfill": "^6.26.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-react": "^6.24.1",
    "babel-preset-stage-0": "^6.5.0",
    "babel-register": "^6.26.0",
    "babel-watch": "^2.0.2",
    "chai": "^3.5.0",
    "chai-as-promised": "^5.3.0",
    "chai-equal-jsx": "^1.0.9",
    "css-loader": "^0.28.11",
    "eslint": "^2.13.1",
    "eslint-plugin-babel": "^3.3.0",
    "eslint-plugin-react": "^5.2.2",
    "ignore-styles": "^5.0.1",
    "istanbul": "^0.4.5",
    "jsdom": "^28.1.0",
    "jsdom-global": "^3.0.2",
    "mocha": "^2.4.5",
    "nyc": "^11.9.0",
    "react-shallow-renderer": "^16.15.0",
    "redux-mock-store": "^1.5.5",
    "style-loader": "^0.13.2",
    "webpack": "^1.13.0",
    "webpack-dev-middleware": "^1.6.1",
    "webpack-dev-server": "^1.14.1",
    "webpack-hot-middleware": "^2.10.0"
  },
  "nyc": {
    "include": [
      "src/**/*.js",
      "src/**/*.jsx"
    ],
    "exclude": [
      "build",
      "test/**",
      "**/*.test.js",
      "**/*.spec.js"
    ],
    "all": true,
    "reporter": [
      "text",
      "lcov"
    ],
    "cache": false
  }
}
