{
  "name": "red-server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "build-watch": "tsc --watch",
    "serve-js": "nodemon --watch dist --ext js --exec 'node dist/index.js'",
    "dev": "concurrently \"npm:build-watch\" \"npm:serve-js\""
  },
  "dependencies": {
    "@red/shared": "file:../shared",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}
